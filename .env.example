# Mifos Loan Simulator — Environment Variables
# Copy this file to .env and fill in your values

# App
DEBUG=False

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Mifos X Fineract API (optional — for live loan fetch feature)
FINERACT_BASE_URL=https://demo.fineract.dev/fineract-provider/api/v1
FINERACT_USERNAME=mifos
FINERACT_PASSWORD=password
FINERACT_TENANT=default
